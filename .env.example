# HoodSwarm environment variables
# Copy this file to .env.local and fill in your Supabase project values.

# --- Supabase (required for auth + persistence) ---
# Project URL and publishable (anon) key from:
# Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
# Legacy anon key also supported as a fallback:
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- NVIDIA AI (OpenAI-compatible) — powers the live 7-agent debate ---
# Server-side only. Get a key at https://build.nvidia.com
# If unset, the app falls back to the built-in local debate engine.
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
# Fast + reliable default; swap for a larger model (e.g. meta/llama-3.3-70b-instruct) if your tier is quick.
NVIDIA_MODEL=meta/llama-3.1-8b-instruct
